# NodePIN — Caddy reverse proxy
# Automatic HTTPS (Let's Encrypt) for the dashboard.
# Requires NODEPIN_DOMAIN to point (DNS A record) to this server.
{$NODEPIN_DOMAIN} {
	reverse_proxy nodepin_control_panel:{$DASHBOARD_PORT}
	encode gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}
}
