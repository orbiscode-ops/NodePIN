# ═══════════════════════════════════════════
# NodePIN - Environment Template
# انسخ هذا الملف إلى: .env
# ═══════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# عزل المشروع (Project Isolation)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# يضمن أن كل موارد Docker تبدأ باسم المشروع ولا تتعارض مع مشاريع أخرى على نفس السيرفر.
COMPOSE_PROJECT_NAME=nodepin

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# اختيار الشبكات (Network Selection)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# اكتب فقط الشبكات التي تريد تشغيلها، مفصولة بفاصلة.
# القيم المدعومة:
#   mysterium, storj, traffmonetizer, iproyal, peer2profit, repocket,
#   earnapp, bitping, nodepay, grass, packetstream, meson, gradient,
#   proxyrack, uprock, huddle01, titan
# مثال لتشغيل واحدة فقط: ENABLED_NETWORKS=mysterium
ENABLED_NETWORKS=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# عام (Global)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODEPIN_VPS_IP=your_server_ip_here
NODEPIN_DOMAIN=your-domain-or-ip
NODEPIN_TIMEZONE=Asia/Riyadh

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# المنافذ (Ports) — غيّرها فقط لو تعارضت مع مشروع آخر على السيرفر
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DASHBOARD_PORT=3000
MYST_TEQUILAPI_PORT=4050
MYST_UI_PORT=4449
STORJ_PORT=28967
STORJ_DASHBOARD_PORT=14002

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Control Panel (Dashboard)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# مفتاح API اختياري للوصول البرمجي (header: x-api-key)
DASHBOARD_API_KEY=change_this_to_random_string

# ── المصادقة (تسجيل الدخول) ──
# ضع كلمة مرور لتفعيل حماية اللوحة. اتركها فارغة = لا مصادقة (غير موصى للإنتاج).
DASHBOARD_PASSWORD=change_this_strong_password
# سر توقيع الجلسات (سلسلة عشوائية طويلة). لو تركت فارغة تُنشأ عشوائياً وتُفقد عند إعادة التشغيل.
SESSION_SECRET=change_this_to_a_long_random_string
# اجعلها true عند استخدام HTTPS (مع Caddy) لتأمين الكوكي
COOKIE_SECURE=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Mysterium Network (nodepin_myst)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# لا تُرفع هذه القيم لـ Git أبداً!
MYST_IDENTITY_PASSPHRASE=your_myst_identity_passphrase
MYST_CONSUMER_MODE=true
MYST_COUNTRY_FILTER=us
MYST_MAX_SESSION_MINUTES=30
MYST_API_URL=http://nodepin_myst:4050
# TEQUILAPI endpoint داخل شبكة nodepin-net

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Storj Node (nodepin_storj)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
STORJ_WALLET=your_ethereum_wallet_address
STORJ_EMAIL=your_email_for_storj
STORJ_STORAGE_SIZE=500GB
STORJ_BANDWIDTH=100TB
STORJ_API_URL=http://nodepin_storj:14002
# identity generates on first run — mount a volume to persist it!

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CI/CD (GitLab CI)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# هذه تُضاف في GitLab CI/CD Variables فقط، لا هنا.
# SSH_PRIVATE_KEY=
# SSH_USER=root
# SSH_HOST=${NODEPIN_VPS_IP}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Traffmonetizer (nodepin_traffmonetizer)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TRAFFMONETIZER_TOKEN=your_traffmonetizer_token

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# IPRoyal Pawns (nodepin_iproyal)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
IPROYAL_EMAIL=your_iproyal_email
IPROYAL_PASS=your_iproyal_password
IPROYAL_DEVICE=nodepin

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Peer2Profit (nodepin_peer2profit)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PEER2PROFIT_EMAIL=your_peer2profit_email

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Repocket (nodepin_repocket)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REPOCKET_EMAIL=your_repocket_email
REPOCKET_API_KEY=your_repocket_api_key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EarnApp / Bright Data (nodepin_earnapp)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# UUID فريد — أنشئه على: https://earnapp.com/i/sdk-node-uuid
EARNAPP_UUID=your_earnapp_uuid

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Bitping (nodepin_bitping) ✅ أرباح حية
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# سجّل على: https://app.bitping.com
BITPING_EMAIL=your_bitping_email
BITPING_PASSWORD=your_bitping_password
BITPING_API_URL=http://nodepin_bitping:9090

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Nodepay (nodepin_nodepay)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# انسخ الـ Token من: https://app.nodepay.ai → Settings → API Token
NODEPAY_TOKEN=your_nodepay_token

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Grass / Wynd Network (nodepin_grass)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# سجّل على: https://app.getgrass.io/register
GRASS_USER=your_grass_email
GRASS_PASS=your_grass_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PacketStream (nodepin_packetstream)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# انسخ الـ CID من: https://packetstream.io/dashboard
PACKETSTREAM_CID=your_packetstream_cid

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Meson Network (nodepin_meson) ✅ أرباح حية
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# انسخ الـ Token من: https://dashboard.meson.network
MESON_TOKEN=your_meson_token
MESON_API_URL=http://nodepin_meson:19090
MESON_PORT=19090

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Gradient Network (nodepin_gradient)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# سجّل على: https://app.gradient.network
GRADIENT_EMAIL=your_gradient_email
GRADIENT_PASS=your_gradient_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Proxyrack (nodepin_proxyrack)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# سجّل على: https://peer.proxyrack.com
PROXYRACK_UUID=your_proxyrack_uuid
PROXYRACK_API_KEY=your_proxyrack_api_key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Uprock (nodepin_uprock)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# سجّل على: https://uprock.com
UPROCK_EMAIL=your_uprock_email
UPROCK_PASSWORD=your_uprock_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Huddle01 Media Node (nodepin_huddle01) ✅ أرباح حية
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# انسخ الـ API Key من: https://node.huddle01.com
HUDDLE01_API_KEY=your_huddle01_api_key
HUDDLE01_API_URL=http://nodepin_huddle01:4001
HUDDLE01_PORT=4001

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Titan Network (nodepin_titan)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# انسخ الـ Activation Hash من: https://storage.titannet.io
TITAN_HASH=your_titan_activation_hash
TITAN_URL=https://cassini.titannet.io:2345/rpc/v0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Anyone Protocol Relay (nodepin_anyone)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ANYONE_NICKNAME=nodepin_relay
ANYONE_WALLET=your_ethereum_wallet_address_here
ANYONE_PORT=9001
