# ═══════════════════════════════════════════
# NodePIN — .gitignore
# ═══════════════════════════════════════════

# ── Kiro IDE (local dev tool — not part of the project) ──
.kiro/

# ── Secrets & Environment ──────────────────
.env
.env.local
.env.*.local
*.env
**/.env
services/anyone/anonrc

# ── Node.js ────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnp.*
package-lock.json.bak

# ── Build outputs ──────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/

# ── Test & Coverage ────────────────────────
coverage/
**/coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ── Logs ───────────────────────────────────
logs/
*.log
*.log.*

# ── Docker local overrides ─────────────────
docker-compose.override.yml
docker-compose.local.yml

# ── Volumes & Persisted Data ───────────────
data/
volumes/
*.db
*.sqlite
*.sqlite3
/mnt/

# ── OS ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDEs & Editors ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# ── Temporary files ────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.rej

# ── Security ───────────────────────────────
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*secret*
*credential*
auth.json
